{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Create Order Request",
  "description": "Request schema for creating a new order in the ecommerce application",
  "type": "object",
  "required": [
    "customer",
    "items",
    "shippingAddress",
    "billingAddress"
  ],
  "properties": {
    "customer": {
      "type": "object",
      "description": "Customer information",
      "required": [
        "email",
        "firstName",
        "lastName"
      ],
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Customer email address"
        },
        "firstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Customer first name"
        },
        "lastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Customer last name"
        },
        "phone": {
          "type": "string",
          "description": "Customer phone number"
        }
      }
    },
    "items": {
      "type": "array",
      "description": "List of items in the order",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "productId",
          "quantity",
          "price"
        ],
        "properties": {
          "productId": {
            "type": "string",
            "description": "Unique product identifier"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Quantity of the item"
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "description": "Unit price of the item in USD"
          }
        }
      }
    },
    "shippingAddress": {
      "type": "object",
      "description": "Shipping address for the order",
      "required": [
        "street",
        "city",
        "state",
        "zipCode",
        "country"
      ],
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Street address"
        },
        "city": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "City name"
        },
        "state": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "State or province"
        },
        "zipCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20,
          "description": "Postal code"
        },
        "country": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Country name"
        }
      }
    },
    "billingAddress": {
      "type": "object",
      "description": "Billing address for the order",
      "required": [
        "street",
        "city",
        "state",
        "zipCode",
        "country"
      ],
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Street address"
        },
        "city": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "City name"
        },
        "state": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "State or province"
        },
        "zipCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20,
          "description": "Postal code"
        },
        "country": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Country name"
        }
      }
    },
    "paymentMethod": {
      "type": "string",
      "description": "Payment method (e.g., credit_card, paypal, etc.)",
      "enum": [
        "credit_card",
        "debit_card",
        "paypal",
        "bank_transfer"
      ]
    },
    "notes": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional order notes or special instructions"
    }
  }
}
