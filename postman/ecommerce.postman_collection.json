{
  "info": {
    "name": "Ecommerce API",
    "_postman_id": "ecommerce-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Ecommerce API Gateway collection"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{ApiToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.ecommerce.osbornesupremacy.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/orders",
          "host": ["{{baseUrl}}"],
          "path": ["orders"]
        },
        "body": {
          "mode": "raw",
          "options": {
            "raw": {
              "language": "json"
            }
          },
          "raw": "{\n  \"customerId\": \"{{$randomUUID}}\",\n  \"currency\": \"{{$randomCurrencyCode}}\",\n  \"shippingAddress\": \"{{$randomStreetAddress}}\",\n  \"items\": [\n    {\n      \"sku\": \"SKU-{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}\",\n      \"name\": \"{{$randomProductName}}\",\n      \"quantity\": {{$randomInt}},\n      \"unitPrice\": {{$randomPrice}}\n    }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create Order returns success status', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
